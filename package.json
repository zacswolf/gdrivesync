{
  "name": "gdrivesync-vscode-extension",
  "displayName": "GDriveSync",
  "description": "Google Drive to Markdown or CSV sync for VS Code and agent-friendly CLI workflows.",
  "version": "0.1.0",
  "publisher": "zacswolf",
  "license": "MIT",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "google docs",
    "google sheets",
    "ai agents",
    "cli",
    "markdown",
    "csv",
    "xlsx",
    "sync",
    "drive",
    "docs"
  ],
  "main": "./dist/extension.js",
  "bin": {
    "gdrivesync": "./dist/cli.js"
  },
  "files": [
    "dist",
    "site",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:gdocSync.signIn",
    "onCommand:gdocSync.signOut",
    "onCommand:gdocSync.linkCurrentFile",
    "onCommand:gdocSync.importGoogleDoc",
    "onCommand:gdocSync.syncCurrentFile",
    "onCommand:gdocSync.syncAll",
    "onCommand:gdocSync.toggleSyncOnOpen",
    "onCommand:gdocSync.unlinkCurrentFile"
  ],
  "contributes": {
    "commands": [
      {
        "command": "gdocSync.signIn",
        "title": "GDriveSync: Sign In",
        "category": "GDriveSync"
      },
      {
        "command": "gdocSync.signOut",
        "title": "GDriveSync: Sign Out",
        "category": "GDriveSync"
      },
      {
        "command": "gdocSync.linkCurrentFile",
        "title": "Link Current File",
        "category": "GDriveSync"
      },
      {
        "command": "gdocSync.importGoogleDoc",
        "title": "Import Google File as New Local File",
        "category": "GDriveSync"
      },
      {
        "command": "gdocSync.syncCurrentFile",
        "title": "Sync Current File",
        "category": "GDriveSync",
        "icon": "$(sync)"
      },
      {
        "command": "gdocSync.syncAll",
        "title": "Sync All Linked Files",
        "category": "GDriveSync"
      },
      {
        "command": "gdocSync.toggleSyncOnOpen",
        "title": "Toggle Sync on Open",
        "category": "GDriveSync"
      },
      {
        "command": "gdocSync.unlinkCurrentFile",
        "title": "Unlink Current File",
        "category": "GDriveSync"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "gdocSync.syncCurrentFile",
          "group": "navigation@100",
          "when": "(resourceLangId == markdown || resourceLangId == csv) && isWorkspaceTrusted && gdocSync.activeFileLinked"
        },
        {
          "command": "gdocSync.toggleSyncOnOpen",
          "group": "navigation@101",
          "when": "(resourceLangId == markdown || resourceLangId == csv) && isWorkspaceTrusted && gdocSync.activeFileLinked"
        },
        {
          "command": "gdocSync.unlinkCurrentFile",
          "group": "navigation@102",
          "when": "(resourceLangId == markdown || resourceLangId == csv) && isWorkspaceTrusted && gdocSync.activeFileLinked"
        }
      ],
      "explorer/context": [
        {
          "command": "gdocSync.linkCurrentFile",
          "group": "navigation@100",
          "when": "(resourceExtname == .md || resourceExtname == .csv) && isWorkspaceTrusted"
        },
        {
          "command": "gdocSync.syncCurrentFile",
          "group": "navigation@101",
          "when": "(resourceExtname == .md || resourceExtname == .csv) && isWorkspaceTrusted"
        },
        {
          "command": "gdocSync.toggleSyncOnOpen",
          "group": "navigation@102",
          "when": "(resourceExtname == .md || resourceExtname == .csv) && isWorkspaceTrusted"
        },
        {
          "command": "gdocSync.unlinkCurrentFile",
          "group": "navigation@103",
          "when": "(resourceExtname == .md || resourceExtname == .csv) && isWorkspaceTrusted"
        }
      ],
      "commandPalette": [
        {
          "command": "gdocSync.signIn"
        },
        {
          "command": "gdocSync.signOut"
        },
        {
          "command": "gdocSync.linkCurrentFile"
        },
        {
          "command": "gdocSync.importGoogleDoc"
        },
        {
          "command": "gdocSync.syncCurrentFile"
        },
        {
          "command": "gdocSync.syncAll"
        },
        {
          "command": "gdocSync.toggleSyncOnOpen"
        },
        {
          "command": "gdocSync.unlinkCurrentFile"
        }
      ]
    },
    "configuration": {
      "title": "GDriveSync",
      "properties": {
        "gdocSync.syncOnOpenDefault": {
          "type": "boolean",
          "default": false,
          "description": "Whether newly linked files should sync automatically when opened."
        },
        "gdocSync.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show a status bar item for the active linked file."
        },
        "gdocSync.unlinkOnMarkdownDelete": {
          "type": "boolean",
          "default": true,
          "description": "Automatically unlink a linked primary local file when that file is deleted. Generated spreadsheet CSV children are not unlinked by this setting."
        },
        "gdocSync.development.desktopClientId": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional override for the Google desktop OAuth client ID while developing locally."
        },
        "gdocSync.development.desktopClientSecret": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional override for the Google desktop OAuth client secret while developing locally. Keep this in user settings only."
        },
        "gdocSync.development.hostedBaseUrl": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional override for the hosted site origin used for the OAuth bridge and Google Picker during development."
        },
        "gdocSync.development.loginHint": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional Google account email hint to reduce repeated account selection in the hosted picker during development."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -w -p .",
    "test": "npm run test:unit && npm run test:extension",
    "test:unit": "vitest run",
    "pretest:extension": "npm run compile",
    "test:extension": "node ./dist/test/runTest.js",
    "cli": "tsx src/cli.ts"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^11.7.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "@types/turndown": "^5.0.6",
    "mammoth": "^1.12.0",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "xlsx": "^0.18.5"
  }
}
