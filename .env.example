GDRIVESYNC_DESKTOP_CLIENT_ID=replace-with-your-google-desktop-client-id
GDRIVESYNC_DESKTOP_CLIENT_SECRET=replace-with-your-google-desktop-client-secret
# Optional:
# GDRIVESYNC_LOGIN_HINT=you@example.com
# Hosted picker URL for picker-based selection and link-share recovery:
# GDRIVESYNC_HOSTED_BASE_URL=https://your-public-gdrivesync-site.example
# OPENAI_API_KEY=replace-with-your-openai-api-key
# ANTHROPIC_API_KEY=replace-with-your-anthropic-api-key
# Maintainer-only release secrets for GitHub Actions bootstrap:
# VSCE_PAT=replace-with-your-vs-code-marketplace-pat
# OVSX_PAT=replace-with-your-open-vsx-pat
